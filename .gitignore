# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# FahrSignal: lokale Secrets / Konfiguration (z. B. Supabase-Keys)
# Anon-Key ist zwar client-öffentlich, aber Service-Keys / private Configs
# dürfen NIE ins Repo. Keys lieber per --dart-define übergeben.
.env
.env.*
*.secret.json
lib/**/secrets.dart

# Vercel
.vercel
# Von Vercel im Build geklontes Flutter-SDK (nur in der CI, nie lokal committen)
/flutter/
